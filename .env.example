PORT=3000

# Local database variables.
# In Railway, map these to the MySQL service variables or rely on MYSQL* fallbacks.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=audit_log_system

# Railway MySQL fallback variables supported by src/config/database.js:
# MYSQLHOST=
# MYSQLPORT=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=

JWT_SECRET=change-this-secret
